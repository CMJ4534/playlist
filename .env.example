APP_ENV=development
EXPO_PUBLIC_APP_ENV=development

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# mock | supabase (supabase = Edge Function /recommend)
EXPO_PUBLIC_RECOMMENDATION_SOURCE=mock

# 로컬: .env.development / EAS production: eas.json env 참고
# cp .env.development .env

# DEV: 실기기 E2E playback debug overlay (__DEV__ 기본 on, 0/false 로 끔)
EXPO_PUBLIC_PLAYBACK_DEBUG=1

# MoodPlay Express backend (실기기: PC LAN IP, 예 http://192.168.0.10:3001)
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001

# YouTube Data API (클라이언트 youtubeRepository.resolveTrack)
EXPO_PUBLIC_YOUTUBE_API_KEY=

# Google OAuth Client ID (expo-auth-session, YouTube 재생목록 저장용)
# Google Cloud Console > OAuth 2.0 Client IDs > Web application type
# Authorized redirect URIs: https://auth.expo.io/@cmj4534/moodplay
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# EXPO_PUBLIC_SENTRY_DSN=

# --- Supabase Edge Function secrets (supabase secrets set) ---
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514
# YOUTUBE_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# RECOMMEND_TIMEOUT_MS=28000

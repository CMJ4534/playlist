    "seed:apply-replacements": "tsx scripts/applySeedReplacements.ts",
    "seed:sync-meta": "tsx scripts/syncSeedMetaFromReport.ts",
    "catalog:collect": "tsx scripts/catalog/collectTracks.ts",
    "catalog:validate": "tsx scripts/catalog/validateTracks.ts",
    "catalog:enrich": "tsx scripts/catalog/enrichTracks.ts",
    "catalog:dedupe": "tsx scripts/catalog/dedupeTracks.ts",
    "catalog:find-topic": "tsx scripts/catalog/findTopicIds.ts",
    "catalog:find-topic:apply": "tsx scripts/catalog/findTopicIds.ts --apply"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",

{
  "name": "moodplay",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "seed:tracks": "tsx scripts/seedTracks.ts",
    "verify:tracks": "tsx scripts/verifyTracks.ts",
